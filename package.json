{
  "name": "lia-coordinate",
  "version": "0.0.1",
  "description": "LiaScript plugin for interactive coordinate systems using JSXGraph",
  "scripts": {
    "build": "parcel build src/index.ts --dist-dir dist --no-scope-hoist"
  },
  "devDependencies": {
